# OCR Server Environment Configuration

# Server binding
OCR_HOST=0.0.0.0
OCR_PORT=8080

# Model paths (falls back to auto-download from S3 if not found)
OCR_DETECTION_MODEL=models/text-detection.rten
OCR_RECOGNITION_MODEL=models/text-recognition.rten

# Max upload size in bytes (default: 10MB)
OCR_MAX_BODY_SIZE=10485760
